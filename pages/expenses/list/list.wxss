.summary-bar {
  margin: 0 28rpx 16rpx;
  padding: 16rpx 24rpx;
  background: #1D9E75;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  text-align: center;
}

.expense-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 24rpx 8rpx;
  padding: 20rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.exp-left { flex: 1; min-width: 0; }
.exp-title {
  font-size: 28rpx;
  color: #2C2C2A;
}
.exp-meta {
  font-size: 24rpx;
  color: #888780;
  margin-top: 4rpx;
  display: block;
}
.exp-amount {
  font-size: 28rpx;
  font-weight: 600;
  color: #E24B4A;
}
