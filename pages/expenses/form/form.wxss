.form-item { margin-bottom: 16px; }
.form-label {
  font-size: 13px;
  color: #888780;
  display: block;
  margin-bottom: 6px;
}

.picker-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px;
  background: #F5F6FA;
  border-radius: 8px;
  font-size: 14px;
  color: #1D1D1B;
}
.picker-arrow { color: #B0B1B5; font-size: 12px; }

.amount-input-box {
  display: flex;
  align-items: center;
  background: #F5F6FA;
  border-radius: 8px;
  padding: 0 12px;
}
.amount-symbol {
  font-size: 20px;
  font-weight: 700;
  color: #1D9E75;
  margin-right: 4px;
}
.amount-input {
  flex: 1;
  height: 48px;
  font-size: 20px;
  font-weight: 600;
  color: #1D1D1B;
}

.desc-input {
  width: 100%;
  height: 80px;
  background: #F5F6FA;
  border-radius: 8px;
  padding: 12px;
  font-size: 14px;
  color: #1D1D1B;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 48px;
  background: #1D9E75;
  color: #fff;
  border-radius: 10px;
  font-size: 16px;
  font-weight: 600;
  border: none;
  margin-top: 20px;
}
.submit-btn[disabled] { opacity: 0.6; }
