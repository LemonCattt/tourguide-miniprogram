/* ===== 登录引导 Banner ===== */
.login-banner {
  margin: 24rpx 24rpx 20rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #1D9E75 0%, #2EA76E 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.banner-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.banner-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.banner-text {
  display: flex;
  flex-direction: column;
}

.banner-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.banner-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.banner-btn {
  background: #FFFFFF;
  color: #1D9E75;
  font-size: 28rpx;
  font-weight: 600;
  padding: 14rpx 32rpx;
  border-radius: 36rpx;
}

/* ===== 功能介绍列表（游客模式） ===== */
.feature-list {
  margin: 0 24rpx;
}

.feature-row-view {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.f-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.f-content {
  display: flex;
  flex-direction: column;
}

.f-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2C2A;
}

.f-desc {
  font-size: 24rpx;
  color: #888780;
  margin-top: 4rpx;
}

/* ===== 已有样式 ===== */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 28rpx 20rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.greeting {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C2C2A;
}

.subtitle {
  font-size: 26rpx;
  color: #888780;
  margin-top: 4rpx;
}

.header-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #1D9E75;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin: 0 24rpx 24rpx;
}

.stat-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1D9E75;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: #888780;
  margin-top: 6rpx;
  display: block;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2A;
  margin: 0 28rpx 16rpx;
}

.quick-grid {
  display: flex;
  gap: 16rpx;
  margin: 0 24rpx;
}

.quick-item {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  text-align: center;
}

.q-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin: 0 auto 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.q-green { background: #E1F5EE; }
.q-teal { background: #E6F1FB; }
.q-amber { background: #FAEEDA; }

.q-text {
  font-size: 26rpx;
  color: #5F5E5A;
}

.tour-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin: 0 24rpx 12rpx;
  padding: 24rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tour-left {
  flex: 1;
  min-width: 0;
}

.tour-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2A;
}

.tour-meta {
  font-size: 24rpx;
  color: #888780;
  margin-top: 6rpx;
  display: block;
}

.tour-right {
  text-align: right;
  margin-left: 16rpx;
}

.tour-date {
  font-size: 22rpx;
  color: #888780;
  margin-top: 4rpx;
  display: block;
}
