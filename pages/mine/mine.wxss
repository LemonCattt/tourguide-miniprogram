/* 个人中心 */

.nav-placeholder {
  height: 88rpx;
}

/* 用户卡片 */
.profile-card {
  background: linear-gradient(135deg, #1A73E8, #2D8CF0);
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn {
  width: 140rpx;
  height: 140rpx;
  padding: 0;
  margin: 0 0 20rpx 0;
  background: transparent;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.profile-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.nickname-input {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  text-align: center;
  background: transparent;
  margin-bottom: 8rpx;
}

.profile-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  background: rgba(255, 255, 255, 0.15);
  padding: 4rpx 32rpx;
  border-radius: 20rpx;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  margin: 0 24rpx 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-box:not(:last-child) {
  border-right: 1rpx solid #F0F0F0;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A73E8;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

/* 菜单 */
.menu-section {
  margin: 0 24rpx;
}

.menu-group {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-title {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 24rpx 12rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-value {
  font-size: 24rpx;
  color: #BBB;
  margin-right: 8rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #CCC;
}

/* 退出登录 */
.logout-area {
  padding: 48rpx 48rpx 24rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF;
  border: 2rpx solid #FF3B30;
  border-radius: 44rpx;
  font-size: 30rpx;
  color: #FF3B30;
  display: flex;
  align-items: center;
  justify-content: center;
}

.version-info {
  text-align: center;
  padding: 20rpx 0 40rpx;
  font-size: 24rpx;
  color: #CCC;
}
