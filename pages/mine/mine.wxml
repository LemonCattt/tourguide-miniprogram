<!-- 个人中心 -->
<view class="container">
  <!-- 自定义导航栏占位 -->
  <view class="nav-placeholder"></view>

  <!-- 用户信息卡片 -->
  <view class="profile-card">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="profile-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
    </button>
    <input 
      class="nickname-input" 
      type="nickname" 
      placeholder="点击设置昵称" 
      value="{{userInfo.nickName}}"
      bindblur="onNicknameChange"
    />
    <text class="profile-desc">领队</text>
  </view>

  <!-- 数据统计 -->
  <view class="stats-card">
    <view class="stat-box">
      <text class="stat-num">{{stats.invoiceCount}}</text>
      <text class="stat-label">发票总数</text>
    </view>
    <view class="stat-box">
      <text class="stat-num">{{stats.roomTaskCount}}</text>
      <text class="stat-label">分房任务</text>
    </view>
    <view class="stat-box">
      <text class="stat-num">{{stats.totalAmount || '0'}}</text>
      <text class="stat-label">金额(元)</text>
    </view>
  </view>

  <!-- 通用设置 -->
  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-title">通用</view>
      <view class="menu-item" bindtap="onTapAbout">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onClearCache">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">清除缓存</text>
        <text class="menu-value">{{cacheSize}}</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onFeedback">
        <text class="menu-icon">💬</text>
        <text class="menu-text">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-area">
    <button class="logout-btn" bindtap="onLogout">退出登录</button>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>领队助手 v1.0.0</text>
  </view>
</view>
