.ann-title { font-size: 18px; font-weight: 700; color: #1D1D1B; line-height: 1.4; }
.ann-meta {
  display: flex;
  gap: 16px;
  margin-top: 10px;
  font-size: 12px;
}
.meta-dest { color: #1D9E75; }
.meta-time { color: #B0B1B5; }

.ann-tags { display: flex; gap: 6px; margin-top: 10px; }
.tag {
  font-size: 10px;
  padding: 2px 8px;
  background: #EDF7F2;
  color: #1D9E75;
  border-radius: 8px;
}

.ann-content {
  font-size: 14px;
  color: #5E5F63;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.attachment-item {
  padding: 10px 12px;
  background: #F5F6FA;
  border-radius: 6px;
  margin-bottom: 6px;
}
.att-name { font-size: 13px; color: #378ADD; }
