.form-card {
  margin: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
}
.form-group { margin-bottom: 24rpx; }
.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #2C2C2A;
  margin-bottom: 10rpx;
  display: block;
}
.form-input {
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #2C2C2A;
}
.form-textarea {
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #2C2C2A;
  min-height: 160rpx;
  width: 100%;
  box-sizing: border-box;
}
.form-row {
  display: flex;
  gap: 16rpx;
}
