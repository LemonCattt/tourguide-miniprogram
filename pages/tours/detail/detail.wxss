.tour-header {
  padding: 24rpx 28rpx 16rpx;
  position: relative;
}
.tour-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C2C2A;
}
.tour-edit {
  position: absolute;
  right: 28rpx;
  top: 28rpx;
  font-size: 26rpx;
  color: #378ADD;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin: 0 24rpx 24rpx;
}
.info-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
}
.info-label {
  font-size: 22rpx;
  color: #888780;
  display: block;
  margin-bottom: 4rpx;
}
.info-value {
  font-size: 28rpx;
  color: #2C2C2A;
  font-weight: 500;
}

.section { margin-bottom: 24rpx; }
.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2A;
  margin: 0 28rpx 16rpx;
}

.cost-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 24rpx;
  padding: 20rpx 24rpx;
}
.cost-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 26rpx;
  color: #5F5E5A;
}
.cost-total {
  font-weight: 600;
  font-size: 30rpx;
  color: #2C2C2A;
  border-bottom: 1rpx solid #E8E9ED;
  padding-bottom: 12rpx;
  margin-bottom: 8rpx;
}
.cost-amt { font-weight: 600; color: #E24B4A; }
.cost-amt-sm { color: #5F5E5A; }

.quick-row {
  display: flex;
  gap: 16rpx;
  margin: 0 24rpx;
}
.quick-btn {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
}
.q-icon-text { font-size: 36rpx; display: block; margin-bottom: 8rpx; }
.q-label { font-size: 24rpx; color: #5F5E5A; }

.day-header {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1D9E75;
  margin: 24rpx 28rpx 12rpx;
}

.item-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 24rpx 8rpx;
  padding: 20rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.item-type {
  font-size: 28rpx;
  color: #2C2C2A;
}
.item-meta {
  font-size: 24rpx;
  color: #888780;
  margin-top: 4rpx;
  display: block;
}
.item-cost {
  font-size: 28rpx;
  font-weight: 600;
  color: #1D9E75;
}
