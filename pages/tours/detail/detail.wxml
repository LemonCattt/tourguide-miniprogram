<view class="container">
  <view class="loading-more" wx:if="{{loading}}">加载中...</view>

  <block wx:if="{{tour}}">
    <!-- 头部信息 -->
    <view class="tour-header">
      <view class="flex-between">
        <text class="tour-name">{{tour.title}}</text>
        <text class="badge {{tour.status === 'ongoing' ? 'badge-green' : tour.status === 'upcoming' ? 'badge-blue' : tour.status === 'ended' ? 'badge-gray' : 'badge-gray'}}">{{tour.status === 'ongoing' ? '进行中' : tour.status === 'upcoming' ? '即将出发' : tour.status === 'ended' ? '已结束' : tour.status || '未知'}}</text>
      </view>
      <text class="tour-edit" bindtap="goEdit">编辑</text>
    </view>

    <!-- 基础信息 -->
    <view class="info-grid">
      <view class="info-item">
        <text class="info-label">目的地</text>
        <text class="info-value">📍 {{tour.destination || '未设置'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">日期</text>
        <text class="info-value">📅 {{tour.startDate}} ~ {{tour.endDate}}</text>
      </view>
      <view class="info-item" wx:if="{{tour.code}}">
        <text class="info-label">团号</text>
        <text class="info-value">🔖 {{tour.code}}</text>
      </view>
    </view>

    <!-- 费用概览 -->
    <view class="section" wx:if="{{expenseReport}}">
      <text class="section-title">费用概览</text>
      <view class="cost-card">
        <view class="cost-row cost-total">
          <text>总费用</text>
          <text class="cost-amt">¥{{expenseReport.total || 0}}</text>
        </view>
        <view class="cost-row" wx:if="{{expenseReport.byType}}">
          <text>交通</text>
          <text class="cost-amt-sm">¥{{expenseReport.byType.transport || 0}}</text>
        </view>
        <view class="cost-row" wx:if="{{expenseReport.byType}}">
          <text>住宿</text>
          <text class="cost-amt-sm">¥{{expenseReport.byType.hotel || 0}}</text>
        </view>
        <view class="cost-row" wx:if="{{expenseReport.byType}}">
          <text>餐饮</text>
          <text class="cost-amt-sm">¥{{expenseReport.byType.food || expenseReport.byType.meal || 0}}</text>
        </view>
      </view>
    </view>

    <!-- 快捷入口 -->
    <view class="section">
      <text class="section-title">快捷操作</text>
      <view class="quick-row">
        <view class="quick-btn" bindtap="goExpenses">
          <text class="q-icon-text">💳</text>
          <text class="q-label">支出明细</text>
        </view>
        <view class="quick-btn" bindtap="goRooms">
          <text class="q-icon-text">🏨</text>
          <text class="q-label">分房方案</text>
        </view>
        <view class="quick-btn" bindtap="goInvoices">
          <text class="q-icon-text">📄</text>
          <text class="q-label">关联发票</text>
        </view>
      </view>
    </view>

    <!-- 行程安排 -->
    <view class="section" wx:if="{{items.length > 0}}">
      <text class="section-title">行程安排</text>
      <block wx:for="{{itemsByDate}}" wx:for-index="date" wx:for-item="dayItems" wx:key="date">
        <text class="day-header">{{date}}</text>
        <view class="item-card" wx:for="{{dayItems}}" wx:for-item="item" wx:key="id">
          <view class="item-left">
            <text class="item-type">{{item.startTime ? (item.startTime + ' · ') : ''}}{{item.title}}</text>
            <text class="item-meta" wx:if="{{item.location}}">📍 {{item.location}}</text>
          </view>
          <text class="item-cost">¥{{item.cost || 0}}</text>
        </view>
      </block>
    </view>

    <!-- 空日程 -->
    <view class="empty-state" wx:if="{{items.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂未安排行程</text>
      <text class="empty-sub">点击编辑可完善行程信息</text>
    </view>
  </block>
</view>
