<view class="login-page">
  <view class="login-header">
    <view class="logo-circle">
      <view class="logo-mountain"></view>
    </view>
    <text class="app-name">领队助手</text>
    <text class="app-desc">智能户外旅行伙伴</text>
  </view>

  <view class="login-bottom">
    <button
      class="login-btn"
      loading="{{isLoading}}"
      disabled="{{isLoading}}"
      bindtap="handleLogin"
    >
      <text class="btn-icon">◈</text>
      <text>{{isLoading ? '登录中...' : '微信手机号一键登录'}}</text>
    </button>

    <view class="privacy-agreement" catchtap="onTogglePrivacy">
      <view class="privacy-check {{agreedPrivacy ? 'checked' : ''}}">✓</view>
      <text class="privacy-text">
        登录即表示同意
        <text class="privacy-link" catchtap="openServiceAgreement">《用户服务协议》</text>和
        <text class="privacy-link" catchtap="openPrivacyPolicy">《隐私政策》</text>
      </text>
    </view>

    <view class="back-home" bindtap="goBack">
      <text class="back-home-text">暂不登录，返回首页</text>
    </view>
  </view>
</view>
