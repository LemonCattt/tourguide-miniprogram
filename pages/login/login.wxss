.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #3CB371 0%, #2EA76E 60%, #F5F6FA 60%, #F5F6FA 100%);
  display: flex;
  flex-direction: column;
}

.login-header {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

/* Simple mountain icon using CSS borders */
.logo-mountain {
  width: 0;
  height: 0;
  border-left: 36rpx solid transparent;
  border-right: 36rpx solid transparent;
  border-bottom: 60rpx solid #FFFFFF;
  position: relative;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 6rpx;
  margin-bottom: 16rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  letter-spacing: 2rpx;
}

.login-bottom {
  padding: 60rpx 48rpx 80rpx;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  background: #2EA76E;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.login-btn::after { border: none; }

.login-btn:active { opacity: 0.85; }

.btn-icon {
  font-size: 36rpx;
}

.privacy-agreement {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  margin-top: 32rpx;
  padding: 0 20rpx;
}

.privacy-check {
  width: 32rpx;
  height: 32rpx;
  min-width: 32rpx;
  margin-right: 10rpx;
  margin-top: 2rpx;
  border-radius: 50%;
  border: 2rpx solid #CCC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: transparent;
  transition: all 0.2s;
}

.privacy-check.checked {
  background: #2EA76E;
  border-color: #2EA76E;
  color: #FFFFFF;
}

.privacy-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.privacy-link {
  color: #2EA76E;
}

.back-home {
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
  padding: 16rpx;
}

.back-home-text {
  font-size: 26rpx;
  color: #999;
}
