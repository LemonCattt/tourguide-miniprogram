.upload-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30px 20px;
  gap: 8px;
}
.upload-icon { font-size: 40px; margin-bottom: 4px; }
.upload-title { font-size: 18px; font-weight: 600; color: #1D1D1B; }
.upload-desc { font-size: 13px; color: #888780; }
.upload-hint { font-size: 11px; color: #B0B1B5; text-align: center; line-height: 1.5; }

.btn-upload {
  margin-top: 12px;
  padding: 10px 28px;
  background: #1D9E75;
  color: #fff;
  border-radius: 8px;
  font-size: 14px;
  border: none;
}

.file-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 14px;
}

.guest-item {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #EEEEF0;
}
.guest-main { flex: 1; display: flex; gap: 12px; align-items: center; }
.guest-name { font-size: 14px; font-weight: 500; color: #1D1D1B; min-width: 60px; }
.guest-gender { font-size: 12px; color: #378ADD; }
.guest-phone { font-size: 12px; color: #888780; margin-left: auto; }
.btn-remove {
  font-size: 18px;
  color: #E24B4A;
  padding: 0 8px;
}

.submit-btn {
  width: 100%;
  height: 46px;
  background: #1D9E75;
  color: #fff;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 600;
  border: none;
  margin-top: 16px;
}

.loading-state {
  text-align: center;
  padding: 40px 0;
  font-size: 14px;
  color: #888780;
}
