<view class="container">
  <!-- 上传区域 -->
  <view class="card upload-card" wx:if="{{!importing && guests.length === 0}}">
    <view class="upload-icon">📄</view>
    <text class="upload-title">导入团员名单</text>
    <text class="upload-desc">支持 Excel (.xlsx/.xls) 和 CSV 格式</text>
    <text class="upload-hint">格式：姓名,性别,年龄,电话,身份证,室友</text>
    <button class="btn-upload" bindtap="chooseFile">选择文件</button>
  </view>

  <!-- 文件已选 -->
  <view class="card" wx:if="{{fileName && guests.length === 0 && !importing}}">
    <view class="file-info">
      <text>已选择: {{fileName}}</text>
      <text class="link" bindtap="chooseFile">重新选择</text>
    </view>
  </view>

  <!-- 预览列表 -->
  <view class="card" wx:if="{{guests.length > 0}}">
    <view class="section-title">
      <text>预览 ({{guests.length}} 人)</text>
      <text class="link" bindtap="chooseFile">重新导入</text>
    </view>

    <view class="guest-item" wx:for="{{guests}}" wx:key="index">
      <view class="guest-main" data-index="{{index}}" bindtap="previewGuest">
        <text class="guest-name">{{item.name || item['姓名'] || '-'}}</text>
        <text class="guest-gender">{{item.gender || item['性别'] || '-'}}</text>
        <text class="guest-phone" wx:if="{{item.phone || item['电话']}}">{{item.phone || item['电话']}}</text>
      </view>
      <text class="btn-remove" data-index="{{index}}" bindtap="removeGuest">×</text>
    </view>

    <button class="submit-btn" bindtap="confirmImport" loading="{{importing}}">
      确认导入 {{guests.length}} 人
    </button>
  </view>

  <view wx:if="{{importing}}" class="loading-state">
    <text>解析中...</text>
  </view>
</view>
