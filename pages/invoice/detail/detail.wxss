.invoice-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 0;
}

.invoice-type {
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 10px;
  margin-bottom: 10px;
}
.invoice-type.approved { background: #D4EDDA; color: #1D9E75; }

.invoice-amount {
  font-size: 28px;
  font-weight: 700;
  color: #1D1D1B;
}

/* 标签行 */
.invoice-tags {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 12rpx;
}

.type-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-vat_special { background: #E8F0FE; color: #1A73E8; }
.tag-vat_normal { background: #E1F5EE; color: #1D9E75; }
.tag-vat_electronic { background: #E6F1FB; color: #378ADD; }
.tag-train_ticket { background: #FAEEDA; color: #BA7517; }
.tag-taxi_receipt { background: #FAEEDA; color: #BA7517; }
.tag-flight_itinerary { background: #F3E8FF; color: #7C3AED; }
.tag-other { background: #F5F6FA; color: #888780; }

.amount { color: #1D9E75; font-weight: 600; }

.file-card {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px;
  background: #F5F6FA;
  border-radius: 12px;
  border: 1px solid #E5E6EB;
}

.file-icon {
  font-size: 36px;
  width: 52px;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 10px;
  border: 1px solid #E5E6EB;
  flex-shrink: 0;
}

.file-info {
  flex: 1;
  min-width: 0;
}

.file-name {
  font-size: 14px;
  font-weight: 500;
  color: #1D1D1B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
  margin-bottom: 4px;
}

.file-tip {
  font-size: 12px;
  color: #378ADD;
}

.remark-text {
  font-size: 14px;
  color: #5E5F63;
  line-height: 1.6;
}

/* 操作按钮区 */
.action-area {
  padding-bottom: 20px;
}

.btn-group {
  display: flex;
  gap: 12px;
  margin-bottom: 12px;
}

.btn-group:last-child {
  margin-bottom: 0;
}

.secondary-actions {
  margin-top: 8px;
}

.btn-edit {
  flex: 1;
  background: #FFFFFF;
  color: #1A73E8;
  font-size: 14px;
  border-radius: 8px;
  border: 1px solid #1A73E8;
  padding: 10px 0;
}

.btn-delete {
  flex: 1;
  background: #FFFFFF;
  color: #999;
  font-size: 14px;
  border-radius: 8px;
  border: 1px solid #D0D0D0;
  padding: 10px 0;
}

/* 扩展信息行样式 */
.info-row .info-value.ext-field {
  color: #5E5F63;
  font-size: 13px;
}

/* 核销查验区域 */
.verify-status-row {
  padding: 12rpx 0 16rpx;
  text-align: center;
}

.verify-status-tag {
  display: inline-block;
  padding: 6rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.verify-status-tag.verify-ok {
  background: #D4EDDA;
  color: #1D9E75;
}

.verify-status-tag.verify-invalid {
  background: #F8D7DA;
  color: #C0392B;
}

.verify-status-tag.verify-checked {
  background: #E8F0FE;
  color: #1A73E8;
}
