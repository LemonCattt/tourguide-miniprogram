<view class="container">
  <!-- 选择行程 -->
  <view class="card">
    <view class="section-title">选择行程</view>
    <picker mode="selector" range="{{tours}}" range-key="title" bindchange="onTourChange">
      <view class="picker-box">
        <text wx:if="{{tours.length === 0}}">暂无行程</text>
        <text wx:elif="{{tourId}}">{{tours[tourPickerIndex].title}}</text>
        <text wx:else>全部行程</text>
        <text class="picker-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 发票列表 -->
  <view class="card">
    <view class="section-title">
      <text>待抵扣发票 ({{invoices.length}})</text>
      <view class="section-actions">
        <text class="link" bindtap="selectAll">全选</text>
        <text class="link danger" bindtap="clearSelection" wx:if="{{selectedIds.length > 0}}">清空</text>
      </view>
    </view>

    <block wx:if="{{invoices.length > 0}}">
      <view
        class="invoice-item {{selectedIds.indexOf(item.id) >= 0 ? 'selected' : ''}}"
        wx:for="{{invoices}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="toggleSelect"
      >
        <view class="item-check">
          <view class="check-box {{selectedIds.indexOf(item.id) >= 0 ? 'checked' : ''}}">
            <text wx:if="{{selectedIds.indexOf(item.id) >= 0}}">✓</text>
          </view>
        </view>
        <view class="item-info">
          <text class="item-no">{{item.invoiceNumber || '无号码'}}</text>
          <text class="item-seller">{{item.categoryText}}</text>
        </view>
        <view class="item-amount">¥{{item.amountText}}</view>
      </view>
    </block>
    <view wx:else class="empty-state">
      <text class="empty-text">暂无待使用的发票</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar" wx:if="{{selectedIds.length > 0}}">
    <text class="action-count">已选 {{selectedIds.length}} 张</text>
    <button class="btn-primary" bindtap="doOptimize" loading="{{loading}}">计算抵扣</button>
  </view>

  <!-- 优化结果 -->
  <view class="card" wx:if="{{optimizeResult}}">
    <view class="section-title">抵扣方案</view>
    <view class="result-row highlight">
      <text class="result-label">可抵扣金额</text>
      <text class="result-value">¥{{optimizeResult.deduction}}</text>
    </view>
    <view class="result-row">
      <text class="result-label">发票总额</text>
      <text class="result-value">¥{{totalAmount}}</text>
    </view>
    <view class="result-row">
      <text class="result-label">可抵税额</text>
      <text class="result-value">¥{{totalTax}}</text>
    </view>
  </view>
</view>
