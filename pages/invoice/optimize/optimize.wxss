.section-actions { display: flex; gap: 12px; }
.link { font-size: 13px; color: #378ADD; }
.link.danger { color: #E24B4A; }

.picker-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px;
  background: #F5F6FA;
  border-radius: 8px;
  font-size: 14px;
}

.invoice-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #EEEEF0;
}
.invoice-item.selected { background: #EDF7F2; margin: 0 -14px; padding-left: 14px; padding-right: 14px; border-radius: 6px; }

.item-check { margin-right: 10px; }
.check-box {
  width: 20px; height: 20px;
  border: 2px solid #B0B1B5;
  border-radius: 4px;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; color: #fff;
}
.check-box.checked { background: #1D9E75; border-color: #1D9E75; }

.item-info { flex: 1; display: flex; flex-direction: column; gap: 2px; }
.item-no { font-size: 14px; color: #1D1D1B; }
.item-seller { font-size: 12px; color: #888780; }
.item-amount { font-size: 15px; font-weight: 600; color: #1D9E75; }

.action-bar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px;
  background: #fff;
  border-radius: 10px;
  margin-bottom: 14px;
}
.action-count { font-size: 13px; color: #888780; flex: 1; }
.btn-primary, .btn-secondary {
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 13px;
  border: none;
  line-height: 1.4;
}
.btn-primary { background: #1D9E75; color: #fff; }
.btn-secondary { background: #EEEEF0; color: #5E5F63; }

.result-row {
  display: flex;
  justify-content: space-between;
  padding: 8px 0;
}
.result-row.highlight {
  background: #EDF7F2;
  border-radius: 6px;
  padding: 10px 12px;
  margin: 8px -12px;
}
.result-label { font-size: 14px; color: #5E5F63; }
.result-value { font-size: 16px; font-weight: 700; color: #1D9E75; }
